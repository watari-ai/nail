#!/usr/bin/env python3
"""
nail — NAIL Language Interpreter CLI

Usage:
  nail run <file.nail>       Run a NAIL program
  nail check <file.nail>     Check a NAIL program (L0-L2) without running
  nail version               Show interpreter version
"""

import sys
import json
from pathlib import Path

sys.path.insert(0, str(Path(__file__).parent))

from interpreter import Checker, Runtime, CheckError, NailTypeError, NailEffectError, NailRuntimeError


def load(path: str) -> dict:
    p = Path(path)
    if not p.exists():
        print(f"✗ File not found: {path}", file=sys.stderr)
        sys.exit(1)
    if p.suffix != ".nail":
        print(f"✗ Not a .nail file: {path}", file=sys.stderr)
        sys.exit(1)
    try:
        with open(p) as f:
            return json.load(f)
    except json.JSONDecodeError as e:
        print(f"✗ Invalid JSON: {e}", file=sys.stderr)
        sys.exit(1)


def cmd_check(path: str):
    spec = load(path)
    try:
        checker = Checker(spec)
        checker.check()
        print(f"✓ {path}")
        print(f"  L0: JSON schema — OK")
        print(f"  L1: Type check  — OK")
        print(f"  L2: Effect check — OK")
    except CheckError as e:
        print(f"✗ Check error: {e}", file=sys.stderr)
        sys.exit(1)
    except NailTypeError as e:
        print(f"✗ Type error: {e}", file=sys.stderr)
        sys.exit(1)
    except NailEffectError as e:
        print(f"✗ Effect error: {e}", file=sys.stderr)
        sys.exit(1)


def cmd_run(path: str):
    spec = load(path)
    # Check first
    try:
        checker = Checker(spec)
        checker.check()
    except (CheckError, NailTypeError, NailEffectError) as e:
        print(f"✗ Verification failed: {e}", file=sys.stderr)
        sys.exit(1)

    # Run
    try:
        runtime = Runtime(spec)
        result = runtime.run()
        if result is not None and not isinstance(result, type(None)):
            from interpreter.runtime import UNIT
            if result is not UNIT:
                print(f"→ {result}")
    except NailRuntimeError as e:
        print(f"✗ Runtime error: {e}", file=sys.stderr)
        sys.exit(1)


def main():
    args = sys.argv[1:]

    if not args or args[0] in ("-h", "--help"):
        print(__doc__)
        sys.exit(0)

    cmd = args[0]

    if cmd == "version":
        from interpreter import __version__
        print(f"NAIL interpreter v{__version__}")
        sys.exit(0)

    if cmd == "check":
        if len(args) < 2:
            print("Usage: nail check <file.nail>", file=sys.stderr)
            sys.exit(1)
        cmd_check(args[1])

    elif cmd == "run":
        if len(args) < 2:
            print("Usage: nail run <file.nail>", file=sys.stderr)
            sys.exit(1)
        cmd_run(args[1])

    else:
        print(f"Unknown command: {cmd}", file=sys.stderr)
        print(__doc__)
        sys.exit(1)


if __name__ == "__main__":
    main()
