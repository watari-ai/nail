{
  "nail": "0.8.0",
  "kind": "module",
  "id": "fc_standard_example",
  "doc": "Multi-provider tool definitions — FC Standard (Issue #64). Demonstrates NAIL effect annotations that can be converted to OpenAI, Anthropic, and Gemini formats.",
  "tools": [
    {
      "type": "function",
      "function": {
        "name": "read_file",
        "description": "Read the contents of a file from the local filesystem.",
        "parameters": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "Absolute or relative path to the file."
            },
            "encoding": {
              "type": "string",
              "description": "Text encoding (default: utf-8).",
              "default": "utf-8"
            }
          },
          "required": ["path"]
        },
        "effects": ["FS"]
      }
    },
    {
      "type": "function",
      "function": {
        "name": "write_file",
        "description": "Write content to a file on the local filesystem.",
        "parameters": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "Destination file path."
            },
            "content": {
              "type": "string",
              "description": "Text content to write."
            },
            "overwrite": {
              "type": "boolean",
              "description": "Whether to overwrite an existing file (default: false).",
              "default": false
            }
          },
          "required": ["path", "content"]
        },
        "effects": ["FS"]
      }
    },
    {
      "type": "function",
      "function": {
        "name": "http_get",
        "description": "Send an HTTP GET request to a URL and return the response body.",
        "parameters": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string",
              "description": "Target URL."
            },
            "headers": {
              "type": "object",
              "description": "Optional HTTP headers.",
              "additionalProperties": {"type": "string"}
            }
          },
          "required": ["url"]
        },
        "effects": ["NET"]
      }
    },
    {
      "type": "function",
      "function": {
        "name": "get_current_time",
        "description": "Return the current UTC date and time as an ISO 8601 string.",
        "parameters": {
          "type": "object",
          "properties": {
            "timezone": {
              "type": "string",
              "description": "IANA timezone identifier (default: UTC).",
              "default": "UTC"
            }
          },
          "required": []
        },
        "effects": ["TIME"]
      }
    },
    {
      "type": "function",
      "function": {
        "name": "generate_uuid",
        "description": "Generate a random UUID v4.",
        "parameters": {
          "type": "object",
          "properties": {},
          "required": []
        },
        "effects": ["RAND"]
      }
    }
  ]
}
