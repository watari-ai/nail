{"doc":"Multi-provider tool definitions — FC Standard (Issue #64). Demonstrates NAIL effect annotations that can be converted to OpenAI, Anthropic, and Gemini formats.","id":"fc_standard_example","kind":"module","meta":{"spec_version":"0.9.0"},"nail":"0.8.0","tools":[{"function":{"description":"Read the contents of a file from the local filesystem.","effects":["FS"],"name":"read_file","parameters":{"properties":{"encoding":{"default":"utf-8","description":"Text encoding (default: utf-8).","type":"string"},"path":{"description":"Absolute or relative path to the file.","type":"string"}},"required":["path"],"type":"object"}},"type":"function"},{"function":{"description":"Write content to a file on the local filesystem.","effects":["FS"],"name":"write_file","parameters":{"properties":{"content":{"description":"Text content to write.","type":"string"},"overwrite":{"default":false,"description":"Whether to overwrite an existing file (default: false).","type":"boolean"},"path":{"description":"Destination file path.","type":"string"}},"required":["path","content"],"type":"object"}},"type":"function"},{"function":{"description":"Send an HTTP GET request to a URL and return the response body.","effects":["NET"],"name":"http_get","parameters":{"properties":{"headers":{"additionalProperties":{"type":"string"},"description":"Optional HTTP headers.","type":"object"},"url":{"description":"Target URL.","type":"string"}},"required":["url"],"type":"object"}},"type":"function"},{"function":{"description":"Return the current UTC date and time as an ISO 8601 string.","effects":["TIME"],"name":"get_current_time","parameters":{"properties":{"timezone":{"default":"UTC","description":"IANA timezone identifier (default: UTC).","type":"string"}},"required":[],"type":"object"}},"type":"function"},{"function":{"description":"Generate a random UUID v4.","effects":["RAND"],"name":"generate_uuid","parameters":{"properties":{},"required":[],"type":"object"}},"type":"function"}]}