{
  "doc": "4-agent delegation chain demo — all agents properly declare grants.\n\nChain: Reporter (A) → Analyzer (B) → Processor (C) → Writer (D)\n\nWriter (D) holds FS:write_file with delegation='explicit', forcing every\ncaller in the chain to also declare it in their 'grants' field.\nBecause all agents comply, check_program() returns no errors (FC-E010 free).",
  "nail": "0.9.0",
  "kind": "delegation-chain",
  "defs": [
    {
      "op": "def",
      "name": "write_output",
      "doc": "Writer (D) — owns FS:write_file with explicit delegation.",
      "effects": {
        "allow": [
          {
            "op": "FS:write_file",
            "reversible": false,
            "delegation": "explicit"
          }
        ]
      },
      "grants": ["FS:write_file"],
      "body": []
    },
    {
      "op": "def",
      "name": "run_pipeline",
      "doc": "Processor (C) — orchestrates data pipeline and delegates write to Writer (D).",
      "effects": {
        "allow": [
          {
            "op": "FS:write_file",
            "reversible": false,
            "delegation": "explicit"
          }
        ]
      },
      "grants": ["FS:write_file"],
      "body": [
        {"op": "call", "fn": "write_output"}
      ]
    },
    {
      "op": "def",
      "name": "generate_report",
      "doc": "Analyzer (B) — generates report and delegates to Processor (C).",
      "effects": {
        "allow": [
          {
            "op": "FS:write_file",
            "reversible": false,
            "delegation": "explicit"
          }
        ]
      },
      "grants": ["FS:write_file"],
      "body": [
        {"op": "call", "fn": "run_pipeline"}
      ]
    },
    {
      "op": "def",
      "name": "write_summary",
      "doc": "Reporter (A) — top-level entry point; delegates to Analyzer (B).",
      "effects": {
        "allow": [
          {
            "op": "FS:write_file",
            "reversible": false,
            "delegation": "explicit"
          }
        ]
      },
      "grants": ["FS:write_file"],
      "body": [
        {"op": "call", "fn": "generate_report"}
      ]
    }
  ]
}
