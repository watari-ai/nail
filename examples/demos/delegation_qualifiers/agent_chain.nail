{"defs":[{"body":[],"doc":"Writer (D) \u2014 owns FS:write_file with explicit delegation.","effects":{"allow":[{"delegation":"explicit","op":"FS:write_file","reversible":false}]},"grants":["FS:write_file"],"name":"write_output","op":"def"},{"body":[{"fn":"write_output","op":"call"}],"doc":"Processor (C) \u2014 orchestrates data pipeline and delegates write to Writer (D).","effects":{"allow":[{"delegation":"explicit","op":"FS:write_file","reversible":false}]},"grants":["FS:write_file"],"name":"run_pipeline","op":"def"},{"body":[{"fn":"run_pipeline","op":"call"}],"doc":"Analyzer (B) \u2014 generates report and delegates to Processor (C).","effects":{"allow":[{"delegation":"explicit","op":"FS:write_file","reversible":false}]},"grants":["FS:write_file"],"name":"generate_report","op":"def"},{"body":[{"fn":"generate_report","op":"call"}],"doc":"Reporter (A) \u2014 top-level entry point; delegates to Analyzer (B).","effects":{"allow":[{"delegation":"explicit","op":"FS:write_file","reversible":false}]},"grants":["FS:write_file"],"name":"write_summary","op":"def"}],"doc":"4-agent delegation chain demo \u2014 all agents properly declare grants.\n\nChain: Reporter (A) \u2192 Analyzer (B) \u2192 Processor (C) \u2192 Writer (D)\n\nWriter (D) holds FS:write_file with delegation='explicit', forcing every\ncaller in the chain to also declare it in their 'grants' field.\nBecause all agents comply, check_program() returns no errors (FC-E010 free).","kind":"delegation-chain","nail":"0.9.0"}
