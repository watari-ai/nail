{"doc":"Agent tool suite \u2014 single source of truth for the agent-handoff demo (#105).\nEach tool is annotated with its NAIL effect kind so that filter_by_effects()\ncan grant the right subset to each agent role.","kind":"tool","meta":{"spec_version":"0.9.0"},"nail":"0.9.0","tools":[{"function":{"description":"Read the contents of a file from the local filesystem.","effects":["FS"],"name":"read_file","parameters":{"properties":{"path":{"description":"Absolute or relative path to the file.","type":"string"}},"required":["path"],"type":"object"}},"type":"function"},{"function":{"description":"Write or overwrite a file on the local filesystem.","effects":["FS"],"name":"write_file","parameters":{"properties":{"content":{"description":"Text content to write.","type":"string"},"path":{"description":"Absolute or relative path to the destination file.","type":"string"}},"required":["path","content"],"type":"object"}},"type":"function"},{"function":{"description":"Fetch the body of an HTTP/HTTPS URL and return its text.","effects":["NET"],"name":"fetch_url","parameters":{"properties":{"timeout":{"default":10,"description":"Request timeout in seconds.","type":"integer"},"url":{"description":"The URL to fetch.","type":"string"}},"required":["url"],"type":"object"}},"type":"function"},{"function":{"description":"Emit a structured log entry to the output stream.","effects":["IO"],"name":"log_result","parameters":{"properties":{"level":{"default":"info","description":"Log level: info | warn | error.","enum":["info","warn","error"],"type":"string"},"message":{"description":"Human-readable log message.","type":"string"}},"required":["message"],"type":"object"}},"type":"function"}]}
